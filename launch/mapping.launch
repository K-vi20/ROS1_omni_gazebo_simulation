<?xml version="1.0"?>
<launch>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- ARGUMENTS -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <arg name="world" default="$(find car_robot)/world/office.world"/>
  <arg name="x_pos" default="-4.43"/>
  <arg name="y_pos" default="0.192"/>
  <arg name="z_pos" default="0.195"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 1. โหลด URDF -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <param name="robot_description"
         textfile="$(find car_robot)/urdf/bot.urdf"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 2. เปิด Gazebo พร้อม office world -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name"   value="$(arg world)"/>
    <arg name="paused"       value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"          value="true"/>
    <arg name="headless"     value="false"/>
    <arg name="debug"        value="false"/>
  </include>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 3. Spawn robot -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="spawn_urdf"
        pkg="gazebo_ros"
        type="spawn_model"
        args="-urdf -model bot -param robot_description -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos)"
        output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 4. robot_state_publisher -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        output="screen">
    <param name="publish_frequency" value="50.0"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 5. joint_state_publisher -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="joint_state_publisher"
        pkg="joint_state_publisher"
        type="joint_state_publisher"
        output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 6. Teleop Node (Holonomic) -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="teleop"
        pkg="car_robot"
        type="holonomic_teleop.py"
        output="screen"/>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 7. SLAM - Gmapping -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="slam_gmapping" pkg="gmapping" type="slam_gmapping" output="screen">
    
    <!-- Frame IDs -->
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="odom"/>
    <param name="map_frame" value="map"/>
    
    <!-- Process -->
    <param name="throttle_scans" value="1"/>
    <param name="map_update_interval" value="5.0"/>
    
    <!-- Laser Parameters -->
    <param name="maxUrange" value="10.0"/>
    <param name="sigma" value="0.05"/>
    <param name="kernelSize" value="1"/>
    <param name="lstep" value="0.05"/>
    <param name="astep" value="0.05"/>
    <param name="iterations" value="5"/>
    <param name="lsigma" value="0.075"/>
    <param name="ogain" value="3.0"/>
    <param name="lskip" value="0"/>
    
    <!-- For Holonomic Robot (Omni) -->
    <param name="linearUpdate" value="0.5"/>
    <param name="angularUpdate" value="0.436"/>
    <param name="temporalUpdate" value="-1.0"/>
    <param name="resampleThreshold" value="0.5"/>
    <param name="particles" value="80"/>
    
    <!-- Map Size -->
    <param name="xmin" value="-15.0"/>
    <param name="ymin" value="-15.0"/>
    <param name="xmax" value="15.0"/>
    <param name="ymax" value="15.0"/>
    <param name="delta" value="0.05"/>
    
    <!-- Motion Model Parameters (Holonomic) -->
    <param name="srr" value="0.01"/>
    <param name="srt" value="0.02"/>
    <param name="str" value="0.01"/>
    <param name="stt" value="0.02"/>
    
    <!-- Likelihood Sampling -->
    <param name="llsamplerange" value="0.01"/>
    <param name="llsamplestep" value="0.01"/>
    <param name="lasamplerange" value="0.005"/>
    <param name="lasamplestep" value="0.005"/>
    
    <!-- Output -->
    <param name="transform_publish_period" value="0.05"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- 8. RViz - Visualization -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <node name="rviz"
        pkg="rviz"
        type="rviz"
        args="-d $(find car_robot)/config/mapping.rviz"
        output="screen"/>

</launch>
