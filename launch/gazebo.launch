<?xml version="1.0"?>
<launch>

  <!-- 1. โหลด URDF -->
  <param name="robot_description"
         textfile="$(find car_robot)/urdf/bot.urdf"/>

  <!-- 2. เปิด Gazebo พร้อม office world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name"   value="$(find car_robot)/world/office.world"/>
    <arg name="paused"       value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"          value="true"/>
    <arg name="headless"     value="false"/>
    <arg name="debug"        value="false"/>
  </include>

  <!-- 3. Spawn robot ตรงทางเข้า (x=4, y=0) -->
  <node name="spawn_urdf"
        pkg="gazebo_ros"
        type="spawn_model"
        args="-urdf -model bot -param robot_description -x 4.0 -y 0.0 -z 0.1"
        output="screen"/>

  <!-- 4. robot_state_publisher -->
  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        output="screen">
    <param name="publish_frequency" value="50.0"/>
  </node>

  <!-- 5. joint_state_publisher -->
  <node name="joint_state_publisher"
        pkg="joint_state_publisher"
        type="joint_state_publisher"
        output="screen"/>

  <!-- ❌ ลบ RViz ออก เพราะ mapping.launch และ navigation.launch มี rviz ของตัวเอง -->

</launch>
